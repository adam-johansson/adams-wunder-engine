        "p_max":       piston_output["peak pressure"],
        "break_power": break_power,
        "bsfc":        bsfc,
        "nox_spec":    piston_output["nox_spec"],
    }

    print(f"  T_out        : {results[lp]['T_out']:.1f} C")
    print(f"  p_tdc        : {results[lp]['p_tdc']*1e-5:.2f} bar")
    print(f"  p_max        : {results[lp]['p_max']*1e-5:.2f} bar")
    print(f"  Break power  : {break_power*1e-3:.2f} kW")
    print(f"  BSFC         : {bsfc:.1f} g/kWh")
    print(f"  NOx          : {results[lp]['nox_spec']:.4f} g/kWh")


