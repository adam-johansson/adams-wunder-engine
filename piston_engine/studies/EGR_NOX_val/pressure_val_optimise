    fuel_flow   = piston_output["fuel flow"]
    break_power = piston_output["break power"]
    bsfc        = (fuel_flow / break_power) * (1000 * 1000 * 3600)

    results[lp] = {
        "ca":          ca,
        "p_trace":     p_trace,
        "gross_heat":  piston_output["gross heat release"],
        "T_out":       piston_output["T_out"] - 272.15,
