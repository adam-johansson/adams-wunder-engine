x0_guess = {
    25:  [0.0172,  1.80e5, 315.0, 2.0, (362.5/180)*np.pi, (20/180)*np.pi, 360.0],
    50:  [0.02558, 2.60e5, 315.0, 2.0, (362.0/180)*np.pi, (24/180)*np.pi, 370.0],
    75:  [0.03255, 3.75e5, 315.0, 2.0, (360.0/180)*np.pi, (28/180)*np.pi, 380.0],
    100: [0.0410,  4.55e5, 315.0, 2.0, (361.0/180)*np.pi, (30/180)*np.pi, 390.0],
}

# Bounds: (min, max) per parameter — used to clip/scale, Nelder-Mead has no native bounds
# so we use a soft-penalty approach instead of hard constraints.
bounds = {
    "mf_tot": (0.005, 0.06),
    "p_in":   (1.0e5, 6.0e5),
    "T_in":   (290.0, 360.0),
    "m_wiebe":(0.5, 5.0),
    "phi_sc": ((340/180)*np.pi, (380/180)*np.pi),
    "phi_cd": ((5/180)*np.pi,  (60/180)*np.pi),
    "Twall":  (320.0, 480.0),
}
param_names = ["mf_tot", "p_in", "T_in", "m_wiebe", "phi_sc", "phi_cd", "Twall"]


def unpack(x):
    """x -> dict of named params, clipped to bounds (soft penalty handled separately)"""
    return dict(zip(param_names, x))


def penalty(x):
    """Large penalty if outside bounds, to keep Nelder-Mead in a sane region."""
    pen = 0.0
    for name, val in zip(param_names, x):
        lo, hi = bounds[name]
        if val < lo:
            pen += 1e6 * (lo - val) ** 2
        elif val > hi:
            pen += 1e6 * (val - hi) ** 2
    return pen


def run_case(x, rpm):
    """Run the engine model for one parameter vector, return (ca, p_trace) or None on failure."""
    p = unpack(x)
    piston_input["mf_tot"]  = p["mf_tot"]
    piston_input["v_mean"]  = rpm_to_vmean(rpm)
    piston_input["p_in"]    = p["p_in"]
    piston_input["T_in"]    = p["T_in"]
    piston_input["m_wiebe"] = p["m_wiebe"]
    piston_input["phi_sc"]  = p["phi_sc"]
    piston_input["phi_cd"]  = p["phi_cd"]
    piston_input["Twalls"]  = [p["Twall"]] * 3

    try:
        out = run_piston_engine(piston_input, flags)
    except Exception as e:
        return None

    ca = out["crank angle trace"] * 360 / (2 * np.pi) - 180
    return ca, out["pressure trace"], out


def pressure_objective(x, lp, rpm, exp_data):
    """
    Weighted SSE between calculated and experimental pressure curve.
    Weight increases near the experimental peak pressure location.
    """
    pen = penalty(x)
    if pen > 0:
        # Don't even bother running the (possibly unstable) simulation outside bounds
        return pen

    result = run_case(x, rpm)
    if result is None:
        return 1e12  # simulation failed -> heavy penalty

    ca_calc, p_calc, _ = result
    p_calc_bar = p_calc * 1e-5

    ca_exp = exp_data[:, 0]
    p_exp  = exp_data[:, 1]

    # Interpolate calculated curve onto experimental CA points
    # (only within calculated CA range to avoid extrapolation)
    valid = (ca_exp >= ca_calc.min()) & (ca_exp <= ca_calc.max())
    if valid.sum() < 5:
        return 1e12

    ca_exp_v = ca_exp[valid]
    p_exp_v  = p_exp[valid]
    p_interp = np.interp(ca_exp_v, ca_calc, p_calc_bar)

    # Weight: higher near experimental peak pressure CA location
    ca_peak = ca_exp_v[np.argmax(p_exp_v)]
    sigma = 15.0  # degrees, controls how localized the peak weighting is
    weight = 1.0 + 4.0 * np.exp(-0.5 * ((ca_exp_v - ca_peak) / sigma) ** 2)

    sse = np.sum(weight * (p_interp - p_exp_v) ** 2)
    return sse + pen


# =========================================================
# RUN OPTIMIZATION PER LOAD CASE
# =========================================================
fitted_params = {}
opt_results = {}

for lp in load_percents:
    print(f"\n{'='*60}\nOptimizing {lp}% load\n{'='*60}")
    x0 = x0_guess[lp]
    rpm = rpms[lp]

    start = timer()
    res = minimize(
        pressure_objective,
        x0=x0,
        args=(lp, rpm, exp_pressure[lp]),
        method="Nelder-Mead",
        options={
            "maxiter": 300,
            "xatol": 1e-6,
            "fatol": 1e-3,
            "adaptive": True,   # better for parameters of very different scales
        },
    )
    end = timer()

    fitted_params[lp] = unpack(res.x)
    opt_results[lp] = res

    print(f"  Converged: {res.success} | Final SSE: {res.fun:.2f} | Time: {end-start:.1f} s | nfev: {res.nfev}")
    for name, val in fitted_params[lp].items():
        if name in ("phi_sc", "phi_cd"):
            print(f"    {name:10s}: {val:.4f} rad ({np.degrees(val):.2f} deg)")
        else:
            print(f"    {name:10s}: {val:.5g}")


